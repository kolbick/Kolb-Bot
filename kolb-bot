# ---------------------------------------------------------------------------
#  Interactive menu (whiptail)
# ---------------------------------------------------------------------------
WT_TITLE="Kolb-Bot"
WT_WIDTH=72
WT_HEIGHT=20
WT_LIST_HEIGHT=12

show_result() {
  local title="$1" body="$2"
  whiptail --title "$title" --scrolltext --msgbox "$body" $WT_HEIGHT $WT_WIDTH
}

run_and_show() {
  local title="$1"
  shift
  local output
  output=$("$@" 2>&1) || true
  show_result "$title" "$output"
}

pick_service() {
  local svc
  svc=$(whiptail --title "Choose Service" --menu "Which service?" $WT_HEIGHT $WT_WIDTH 7 \
    "all"        "All services" \
    "kolbbot-api"       "Gateway API" \
    "kolbbot-bridge"    "Bridge API" \
    "kolbbot-voice"     "Voice" \
    "kolbbot-telemetry" "Telemetry" \
    "kolbbot-browser"   "Browser sandbox" \
    "openwebui"         "Open WebUI" \
    3>&1 1>&2 2>&3) || return 1
  if [ "$svc" = "all" ]; then
    echo ""
  else
    echo "$svc"
  fi
}

menu_agents() {
  while true; do
    local choice
    choice=$(whiptail --title "Agent Management" --menu "What would you like to do?" $WT_HEIGHT $WT_WIDTH $WT_LIST_HEIGHT \
      "list"      "List all agents" \
      "create"    "Create a new agent" \
      "delete"    "Delete an agent" \
      "export"    "Export an agent to a file" \
      "import"    "Import an agent from a file" \
      "templates" "View available templates" \
      "back"      "Back to main menu" \
      3>&1 1>&2 2>&3) || return 0

    case "$choice" in
      list)
        run_and_show "Agents" curl -s "http://127.0.0.1:8000/v1/workshop/agents"
        ;;
      create)
        local name role
        name=$(whiptail --title "Create Agent" --inputbox "Agent name:" 10 $WT_WIDTH "" 3>&1 1>&2 2>&3) || continue
        [ -z "$name" ] && continue
        role=$(whiptail --title "Create Agent" --menu "Pick a role:" $WT_HEIGHT $WT_WIDTH 6 \
          "general"    "General purpose assistant" \
          "researcher" "Research and analysis" \
          "coder"      "Software development" \
          "writer"     "Writing and editing" \
          "analyst"    "Data analysis" \
          "custom"     "Enter a custom role" \
          3>&1 1>&2 2>&3) || continue
        if [ "$role" = "custom" ]; then
          role=$(whiptail --title "Create Agent" --inputbox "Custom role:" 10 $WT_WIDTH "" 3>&1 1>&2 2>&3) || continue
          [ -z "$role" ] && role="general"
        fi
        local result
        result=$(curl -s -X POST "http://127.0.0.1:8000/v1/workshop/agents" \
          -H "Content-Type: application/json" \
          -d "{\"name\":\"${name}\",\"role\":\"${role}\",\"model\":\"kolb-bot\",\"safe_mode\":true}" 2>&1)
        show_result "Agent Created" "$result"
        ;;
      delete)
        local agents_json agent_id
        agents_json=$(curl -s "http://127.0.0.1:8000/v1/workshop/agents" 2>/dev/null)
        if [ -z "$agents_json" ] || [ "$agents_json" = "[]" ]; then
          show_result "Delete Agent" "No agents found, or the bridge service is not running."
          continue
        fi
        local menu_args
        menu_args=$(echo "$agents_json" | python3 -c "
import sys, json
try:
    agents = json.load(sys.stdin)
    if isinstance(agents, dict):
        agents = agents.get('agents', [])
    for a in agents:
        aid = a.get('id', 'unknown')
        name = a.get('name', 'unnamed')
        print(f'{aid}\n{name}')
except: pass
" 2>/dev/null)
        if [ -z "$menu_args" ]; then
          show_result "Delete Agent" "Could not parse agent list. Raw response:\n$agents_json"
          continue
        fi
        agent_id=$(eval whiptail --title '"Delete Agent"' --menu '"Select the agent to delete:"' $WT_HEIGHT $WT_WIDTH $WT_LIST_HEIGHT $menu_args 3>&1 1>&2 2>&3) || continue
        if whiptail --title "Confirm Delete" --yesno "Delete agent \"$agent_id\"?\n\nThis cannot be undone." 10 $WT_WIDTH; then
          run_and_show "Delete Agent" curl -s -X DELETE "http://127.0.0.1:8000/v1/workshop/agents/${agent_id}"
        fi
        ;;
      export)
        local agent_id file
        agent_id=$(whiptail --title "Export Agent" --inputbox "Agent ID to export:" 10 $WT_WIDTH "" 3>&1 1>&2 2>&3) || continue
        [ -z "$agent_id" ] && continue
        file=$(whiptail --title "Export Agent" --inputbox "Save to file:" 10 $WT_WIDTH "agent-${agent_id}.json" 3>&1 1>&2 2>&3) || continue
        [ -z "$file" ] && file="agent-${agent_id}.json"
        curl -s "http://127.0.0.1:8000/v1/workshop/agents/${agent_id}/export" > "$file"
        show_result "Export Agent" "Saved to $file"
        ;;
      import)
        local file
        file=$(whiptail --title "Import Agent" --inputbox "Path to JSON file:" 10 $WT_WIDTH "" 3>&1 1>&2 2>&3) || continue
        [ -z "$file" ] && continue
        if [ ! -f "$file" ]; then
          show_result "Import Agent" "File not found: $file"
          continue
        fi
        run_and_show "Import Agent" curl -s -X POST "http://127.0.0.1:8000/v1/workshop/agents/import" \
          -H "Content-Type: application/json" -d "@${file}"
        ;;
      templates)
        run_and_show "Agent Templates" curl -s "http://127.0.0.1:8000/v1/workshop/templates"
        ;;
      back) return 0 ;;
    esac
  done
}

menu_providers() {
  while true; do
    local choice
    choice=$(whiptail --title "Provider Management" --menu "What would you like to do?" $WT_HEIGHT $WT_WIDTH $WT_LIST_HEIGHT \
      "list"    "List configured providers" \
      "quick"   "Quick-add options" \
      "add"     "Add a new provider" \
      "remove"  "Remove a provider" \
      "test"    "Test a provider connection" \
      "models"  "List models from a provider" \
      "back"    "Back to main menu" \
      3>&1 1>&2 2>&3) || return 0

    case "$choice" in
      list)
        run_and_show "Providers" curl -s "http://127.0.0.1:8000/v1/providers"
        ;;
      quick)
        local output
        output=$(curl -s "http://127.0.0.1:8000/v1/providers/quick-add" 2>/dev/null | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    for p in data.get('providers', []):
        needs = ', '.join(p.get('needs', []))
        print(f\"{p['id']:15s} {p['name']:25s} needs: {needs}\")
except Exception as e:
    print(f'Error: {e}')
" 2>&1)
        show_result "Quick-Add Options" "$output"
        ;;
      add)
        local pid ptype
        pid=$(whiptail --title "Add Provider" --inputbox "Provider ID (short name, e.g. 'openai', 'my-ollama'):" 10 $WT_WIDTH "" 3>&1 1>&2 2>&3) || continue
        [ -z "$pid" ] && continue
        ptype=$(whiptail --title "Add Provider" --menu "Provider type:" $WT_HEIGHT $WT_WIDTH 5 \
          "openai"    "OpenAI (or compatible API)" \
          "anthropic" "Anthropic Claude" \
          "gemini"    "Google Gemini" \
          "ollama"    "Ollama (local models)" \
          "cli"       "CLI tool (e.g. codex)" \
          3>&1 1>&2 2>&3) || continue
        if [ "$ptype" = "cli" ]; then
          local cli_cmd
          cli_cmd=$(whiptail --title "Add Provider" --inputbox "CLI command to run:" 10 $WT_WIDTH "" 3>&1 1>&2 2>&3) || continue
          [ -z "$cli_cmd" ] && continue
          local result
          result=$(curl -s -X POST "http://127.0.0.1:8000/v1/providers" \
            -H "Content-Type: application/json" \
            -d "{\"id\":\"${pid}\",\"name\":\"${pid}\",\"type\":\"cli\",\"cli_command\":\"${cli_cmd}\"}" 2>&1)
          show_result "Provider Added" "$result"
        elif [ "$ptype" = "ollama" ]; then
          local api_base
          api_base=$(whiptail --title "Add Provider" --inputbox "Ollama API URL:" 10 $WT_WIDTH "http://localhost:11434/v1" 3>&1 1>&2 2>&3) || continue
          [ -z "$api_base" ] && continue
          local result
          result=$(curl -s -X POST "http://127.0.0.1:8000/v1/providers" \
            -H "Content-Type: application/json" \
            -d "{\"id\":\"${pid}\",\"name\":\"${pid}\",\"type\":\"ollama\",\"api_base\":\"${api_base}\"}" 2>&1)
          show_result "Provider Added" "$result"
        else
          local api_base api_key
          case "$ptype" in
            openai)    api_base="https://api.openai.com/v1" ;;
            anthropic) api_base="https://api.anthropic.com/v1" ;;
            gemini)    api_base="https://generativelanguage.googleapis.com/v1" ;;
          esac
          api_base=$(whiptail --title "Add Provider" --inputbox "API base URL:" 10 $WT_WIDTH "$api_base" 3>&1 1>&2 2>&3) || continue
          api_key=$(whiptail --title "Add Provider" --passwordbox "API key (paste it in, it's hidden):" 10 $WT_WIDTH "" 3>&1 1>&2 2>&3) || continue
          local result
          result=$(curl -s -X POST "http://127.0.0.1:8000/v1/providers" \
            -H "Content-Type: application/json" \
            -d "{\"id\":\"${pid}\",\"name\":\"${pid}\",\"type\":\"${ptype}\",\"api_base\":\"${api_base}\",\"api_key\":\"${api_key}\"}" 2>&1)
          show_result "Provider Added" "$result"
        fi
        ;;
      remove)
        local pid
        pid=$(whiptail --title "Remove Provider" --inputbox "Provider ID to remove:" 10 $WT_WIDTH "" 3>&1 1>&2 2>&3) || continue
        [ -z "$pid" ] && continue
        if whiptail --title "Confirm Remove" --yesno "Remove provider \"$pid\"?" 10 $WT_WIDTH; then
          run_and_show "Remove Provider" curl -s -X DELETE "http://127.0.0.1:8000/v1/providers/${pid}"
        fi
        ;;
      test)
        local pid
        pid=$(whiptail --title "Test Provider" --inputbox "Provider ID to test:" 10 $WT_WIDTH "" 3>&1 1>&2 2>&3) || continue
        [ -z "$pid" ] && continue
        run_and_show "Test Provider" curl -s -X POST "http://127.0.0.1:8000/v1/providers/${pid}/test"
        ;;
      models)
        local pid
        pid=$(whiptail --title "Provider Models" --inputbox "Provider ID:" 10 $WT_WIDTH "" 3>&1 1>&2 2>&3) || continue
        [ -z "$pid" ] && continue
        run_and_show "Models" curl -s "http://127.0.0.1:8000/v1/providers/${pid}/models"
        ;;
      back) return 0 ;;
    esac
  done
}

menu_logs() {
  local svc
  svc=$(pick_service) || return 0
  clear
  echo -e "${CYAN}Tailing logs (Ctrl+C to stop)...${NC}"
  echo ""
  if [ -n "$svc" ]; then
    docker compose -f "${COMPOSE_FILE}" logs -f "$svc"
  else
    docker compose -f "${COMPOSE_FILE}" logs -f
  fi
}

menu_env() {
  local env_file="${SCRIPT_DIR}/.env"
  if [ ! -f "$env_file" ]; then
    if whiptail --title "Settings" --yesno "No .env file found. Create one from the template?" 10 $WT_WIDTH; then
      ensure_env
      show_result "Settings" "Created .env with auto-generated secrets.\nEdit it below to add API keys."
    else
      return 0
    fi
  fi

  while true; do
    local choice
    choice=$(whiptail --title "Settings (.env)" --menu "What would you like to do?" $WT_HEIGHT $WT_WIDTH 6 \
      "view"   "View current settings" \
      "openai" "Set OpenAI API key" \
      "claude" "Set Anthropic/Claude API key" \
      "stt"    "Set speech-to-text engine" \
      "tts"    "Set text-to-speech engine" \
      "back"   "Back to main menu" \
      3>&1 1>&2 2>&3) || return 0

    case "$choice" in
      view)
        local sanitized
        sanitized=$(sed -E 's/(API_KEY=|SECRET_KEY=|TOKEN=)(.{4}).*/\1\2****/g' "$env_file")
        show_result "Current Settings" "$sanitized"
        ;;
      openai)
        local key
        key=$(whiptail --title "OpenAI API Key" --passwordbox "Paste your OpenAI API key:" 10 $WT_WIDTH "" 3>&1 1>&2 2>&3) || continue
        [ -z "$key" ] && continue
        if grep -q "^OPENAI_API_KEY=" "$env_file"; then
          sed -i "s|^OPENAI_API_KEY=.*|OPENAI_API_KEY=${key}|" "$env_file"
        else
          echo "OPENAI_API_KEY=${key}" >> "$env_file"
        fi
        show_result "Saved" "OpenAI API key updated. Restart Kolb-Bot for it to take effect."
        ;;
      claude)
        local key
        key=$(whiptail --title "Anthropic API Key" --passwordbox "Paste your Anthropic API key:" 10 $WT_WIDTH "" 3>&1 1>&2 2>&3) || continue
        [ -z "$key" ] && continue
        if grep -q "^ANTHROPIC_API_KEY=" "$env_file"; then
          sed -i "s|^ANTHROPIC_API_KEY=.*|ANTHROPIC_API_KEY=${key}|" "$env_file"
        else
          echo "ANTHROPIC_API_KEY=${key}" >> "$env_file"
        fi
        show_result "Saved" "Anthropic API key updated. Restart Kolb-Bot for it to take effect."
        ;;
      stt)
        local engine
        engine=$(whiptail --title "Speech-to-Text" --menu "Choose STT engine:" $WT_HEIGHT $WT_WIDTH 3 \
          "whisper" "Whisper (local, no API key)" \
          "openai"  "OpenAI Whisper API (needs key)" \
          3>&1 1>&2 2>&3) || continue
        sed -i "s|^STT_ENGINE=.*|STT_ENGINE=${engine}|" "$env_file"
        if [ "$engine" = "whisper" ]; then
          local model
          model=$(whiptail --title "Whisper Model" --menu "Model size (bigger = more accurate, slower):" $WT_HEIGHT $WT_WIDTH 5 \
            "tiny"   "Fastest, least accurate" \
            "base"   "Good balance (recommended)" \
            "small"  "More accurate, slower" \
            "medium" "High accuracy, much slower" \
            "large"  "Best accuracy, very slow" \
            3>&1 1>&2 2>&3) || model="base"
          sed -i "s|^WHISPER_MODEL=.*|WHISPER_MODEL=${model}|" "$env_file"
        fi
        show_result "Saved" "STT engine set to ${engine}. Restart Kolb-Bot for it to take effect."
        ;;
      tts)
        local engine
        engine=$(whiptail --title "Text-to-Speech" --menu "Choose TTS engine:" $WT_HEIGHT $WT_WIDTH 3 \
          "edge-tts" "Edge TTS (free, high quality)" \
          "openai"   "OpenAI TTS (needs key)" \
          3>&1 1>&2 2>&3) || continue
        sed -i "s|^TTS_ENGINE=.*|TTS_ENGINE=${engine}|" "$env_file"
        show_result "Saved" "TTS engine set to ${engine}. Restart Kolb-Bot for it to take effect."
        ;;
      back) return 0 ;;
    esac
  done
}

cmd_menu() {
  if ! command -v whiptail &>/dev/null; then
    echo -e "${RED}whiptail is not installed. Install it with: sudo apt install whiptail${NC}"
    echo "Falling back to text help."
    cmd_help
    return
  fi

  local ip
  ip=$(get_host_ip)

  while true; do
    local choice
    choice=$(whiptail --title "Kolb-Bot" --menu "Your AI pirate crew, at your service.\n\nUI: http://${ip}:3000" $WT_HEIGHT $WT_WIDTH $WT_LIST_HEIGHT \
      "up"        "Start Kolb-Bot" \
      "down"      "Stop Kolb-Bot" \
      "restart"   "Restart Kolb-Bot" \
      "status"    "View service status" \
      "health"    "Health check all services" \
      "logs"      "View logs" \
      "agents"    "Manage agents" \
      "providers" "Manage AI providers" \
      "settings"  "Edit settings (API keys, voice, etc.)" \
      "pirate"    "Pirate Ship status" \
      "quit"      "Exit" \
      3>&1 1>&2 2>&3) || break

    case "$choice" in
      up)
        clear
        cmd_up
        echo ""
        read -rp "Press Enter to continue..."
        ;;
      down)
        if whiptail --title "Stop Kolb-Bot" --yesno "Stop all services?" 10 $WT_WIDTH; then
          clear
          cmd_down
          echo ""
          read -rp "Press Enter to continue..."
        fi
        ;;
      restart)
        clear
        cmd_restart
        echo ""
        read -rp "Press Enter to continue..."
        ;;
      status)
        local output
        output=$(docker compose -f "${COMPOSE_FILE}" ps 2>&1)
        show_result "Service Status" "$output"
        ;;
      health)
        clear
        cmd_health
        echo ""
        read -rp "Press Enter to continue..."
        ;;
      logs)      menu_logs ;;
      agents)    menu_agents ;;
      providers) menu_providers ;;
      settings)  menu_env ;;
      pirate)
        clear
        cmd_pirate
        echo ""
        read -rp "Press Enter to continue..."
        ;;
      quit) break ;;
    esac
  done
}

# Main dispatch
case "${1:-menu}" in
  up)       cmd_up ;;
  down)     cmd_down ;;
  restart)  cmd_restart ;;
  status)   cmd_status ;;
  logs)     shift; cmd_logs "$@" ;;
  health)   cmd_health ;;
  agent)    shift; cmd_agent "$@" ;;
  provider) shift; cmd_provider "$@" ;;
  voice)    shift; cmd_voice "$@" ;;
  pirate)   cmd_pirate ;;
  verify)   cmd_verify ;;
  urls)     cmd_urls ;;
  menu)     cmd_menu ;;
  help|--help|-h) cmd_help ;;
  *)
    echo -e "${RED}Unknown command: $1${NC}"
    echo "Run 'kolb-bot help' for usage."
    exit 1
    ;;
esac
