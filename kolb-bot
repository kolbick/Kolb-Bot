#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="${SCRIPT_DIR}/docker-compose.yml"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

get_host_ip() {
  # Prefer Tailscale IP if available
  if command -v tailscale &>/dev/null; then
    local ts_ip
    ts_ip=$(tailscale ip -4 2>/dev/null)
    if [ -n "$ts_ip" ]; then
      echo "$ts_ip"
      return
    fi
  fi
  hostname -I 2>/dev/null | awk '{print $1}'
}

banner() {
  echo ""
  echo -e "${CYAN}  Kolb-Bot${NC}"
  echo -e "  ${BLUE}Your AI pirate crew, at your service${NC}"
  echo ""
}

ensure_env() {
  if [ ! -f "${SCRIPT_DIR}/.env" ]; then
    echo -e "${YELLOW}No .env file found. Creating from template...${NC}"
    if [ -f "${SCRIPT_DIR}/.env.example" ]; then
      cp "${SCRIPT_DIR}/.env.example" "${SCRIPT_DIR}/.env"
      GENERATED_TOKEN=$(openssl rand -hex 32 2>/dev/null || head -c 64 /dev/urandom | od -An -tx1 | tr -d ' \n')
      GENERATED_SECRET=$(openssl rand -hex 32 2>/dev/null || head -c 64 /dev/urandom | od -An -tx1 | tr -d ' \n')
      sed -i "s/KOLB_BOT_GATEWAY_TOKEN=.*/KOLB_BOT_GATEWAY_TOKEN=${GENERATED_TOKEN}/" "${SCRIPT_DIR}/.env"
      sed -i "s/WEBUI_SECRET_KEY=.*/WEBUI_SECRET_KEY=${GENERATED_SECRET}/" "${SCRIPT_DIR}/.env"
      echo -e "${GREEN}Created .env with auto-generated secrets.${NC}"
      echo -e "${YELLOW}Edit .env to add your API keys (OPENAI_API_KEY, ANTHROPIC_API_KEY, etc.)${NC}"
    else
      echo -e "${RED}Error: .env.example not found${NC}"
      exit 1
    fi
  fi
}

cmd_up() {
  banner
  echo -e "${GREEN}Starting Kolb-Bot...${NC}"
  ensure_env
  docker compose -f "${COMPOSE_FILE}" up -d --build
  local ip
  ip=$(get_host_ip)
  echo ""
  echo -e "${GREEN}Kolb-Bot is running!${NC}"
  echo ""
  echo -e "  Open WebUI     ${CYAN}http://${ip}:3000${NC}"
  echo -e "  Browser View   ${CYAN}http://${ip}:6080/vnc.html${NC}"
  echo -e "  Bridge API     ${CYAN}http://${ip}:8000${NC}"
  echo -e "  Voice          ${CYAN}http://${ip}:8100${NC}"
  echo -e "  Telemetry      ${CYAN}ws://${ip}:8200${NC}"
  echo -e "  Gateway        ${CYAN}ws://${ip}:18789${NC}"
  echo ""
  echo -e "  First time? Open the WebUI URL on your tablet to create an admin account."
}

cmd_down() {
  echo -e "${YELLOW}Stopping Kolb-Bot...${NC}"
  docker compose -f "${COMPOSE_FILE}" down
  echo -e "${GREEN}All services stopped.${NC}"
}

cmd_restart() {
  echo -e "${YELLOW}Restarting Kolb-Bot...${NC}"
  docker compose -f "${COMPOSE_FILE}" restart
  echo -e "${GREEN}Restarted.${NC}"
}

cmd_status() {
  docker compose -f "${COMPOSE_FILE}" ps
}

cmd_logs() {
  local service="${1:-}"
  if [ -n "$service" ]; then
    docker compose -f "${COMPOSE_FILE}" logs -f "$service"
  else
    docker compose -f "${COMPOSE_FILE}" logs -f
  fi
}

cmd_health() {
  banner
  echo "Service health:"
  echo ""
  for svc in kolbbot-api kolbbot-bridge kolbbot-voice kolbbot-telemetry kolbbot-browser openwebui; do
    local status
    status=$(docker compose -f "${COMPOSE_FILE}" ps --format json "$svc" 2>/dev/null | python3 -c "import sys,json;d=json.load(sys.stdin);print(d.get('Health','unknown'))" 2>/dev/null || echo "not running")
    if [ "$status" = "healthy" ]; then
      echo -e "  ${GREEN}ok${NC}   $svc"
    elif [ "$status" = "not running" ]; then
      echo -e "  ${RED}down${NC} $svc"
    else
      echo -e "  ${YELLOW}wait${NC} $svc"
    fi
  done
  echo ""
}

cmd_agent() {
  local subcmd="${1:-help}"
  shift || true

  case "$subcmd" in
    list)
      curl -s "http://127.0.0.1:8000/v1/workshop/agents" | python3 -m json.tool
      ;;
    create)
      local name="${1:?Usage: kolb-bot agent create <name> [role]}"
      local role="${2:-general}"
      curl -s -X POST "http://127.0.0.1:8000/v1/workshop/agents" \
        -H "Content-Type: application/json" \
        -d "{\"name\":\"${name}\",\"role\":\"${role}\",\"model\":\"kolb-bot\",\"safe_mode\":true}" \
        | python3 -m json.tool
      ;;
    delete)
      local id="${1:?Usage: kolb-bot agent delete <agent-id>}"
      curl -s -X DELETE "http://127.0.0.1:8000/v1/workshop/agents/${id}" | python3 -m json.tool
      ;;
    export)
      local id="${1:?Usage: kolb-bot agent export <agent-id> [file]}"
      local file="${2:-agent-${id}.json}"
      curl -s "http://127.0.0.1:8000/v1/workshop/agents/${id}/export" > "$file"
      echo -e "${GREEN}Exported to ${file}${NC}"
      ;;
    import)
      local file="${1:?Usage: kolb-bot agent import <file.json>}"
      curl -s -X POST "http://127.0.0.1:8000/v1/workshop/agents/import" \
        -H "Content-Type: application/json" \
        -d "@${file}" | python3 -m json.tool
      ;;
    templates)
      curl -s "http://127.0.0.1:8000/v1/workshop/templates" | python3 -m json.tool
      ;;
    *)
      echo "Usage: kolb-bot agent <command>"
      echo ""
      echo "Commands:"
      echo "  list              List all agents"
      echo "  create <name>     Create a new agent"
      echo "  delete <id>       Delete an agent"
      echo "  export <id>       Export agent config as JSON"
      echo "  import <file>     Import agent from JSON file"
      echo "  templates         Show available agent templates"
      ;;
  esac
}

cmd_provider() {
  local subcmd="${1:-help}"
  shift || true

  case "$subcmd" in
    list)
      curl -s "http://127.0.0.1:8000/v1/providers" | python3 -m json.tool
      ;;
    quick)
      curl -s "http://127.0.0.1:8000/v1/providers/quick-add" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for p in data.get('providers', []):
    needs = ', '.join(p.get('needs', []))
    print(f\"  {p['id']:15s} {p['name']:25s} {p['type']:10s} needs: {needs}\")
"
      ;;
    add)
      local id="${1:?Usage: kolb-bot provider add <id> <type> <api_base_or_command> [api_key]}"
      local ptype="${2:?Specify type: openai, anthropic, gemini, ollama, cli}"
      local base_or_cmd="${3:?Specify API base URL or CLI command}"
      local key="${4:-}"
      if [ "$ptype" = "cli" ]; then
        curl -s -X POST "http://127.0.0.1:8000/v1/providers" \
          -H "Content-Type: application/json" \
          -d "{\"id\":\"${id}\",\"name\":\"${id}\",\"type\":\"cli\",\"cli_command\":\"${base_or_cmd}\"}" \
          | python3 -m json.tool
      else
        curl -s -X POST "http://127.0.0.1:8000/v1/providers" \
          -H "Content-Type: application/json" \
          -d "{\"id\":\"${id}\",\"name\":\"${id}\",\"type\":\"${ptype}\",\"api_base\":\"${base_or_cmd}\",\"api_key\":\"${key}\"}" \
          | python3 -m json.tool
      fi
      ;;
    remove)
      local id="${1:?Usage: kolb-bot provider remove <id>}"
      curl -s -X DELETE "http://127.0.0.1:8000/v1/providers/${id}" | python3 -m json.tool
      ;;
    test)
      local id="${1:?Usage: kolb-bot provider test <id>}"
      curl -s -X POST "http://127.0.0.1:8000/v1/providers/${id}/test" | python3 -m json.tool
      ;;
    models)
      local id="${1:?Usage: kolb-bot provider models <id>}"
      curl -s "http://127.0.0.1:8000/v1/providers/${id}/models" | python3 -m json.tool
      ;;
    *)
      echo "Usage: kolb-bot provider <command>"
      echo ""
      echo "Commands:"
      echo "  list              Show configured providers"
      echo "  quick             Show quick-add options"
      echo "  add <id> <type> <url_or_cmd> [key]"
      echo "                    Add a provider"
      echo "  remove <id>       Remove a provider"
      echo "  test <id>         Test a provider connection"
      echo "  models <id>       List models from a provider"
      echo ""
      echo "Types: openai, anthropic, gemini, ollama, cli"
      echo ""
      echo "Examples:"
      echo "  kolb-bot provider add openai openai https://api.openai.com/v1 sk-..."
      echo "  kolb-bot provider add codex cli codex"
      echo "  kolb-bot provider add ollama ollama http://localhost:11434/v1"
      ;;
  esac
}

cmd_voice() {
  local subcmd="${1:-status}"
  case "$subcmd" in
    status)
      curl -s "http://127.0.0.1:8100/health" 2>/dev/null | python3 -m json.tool 2>/dev/null || echo "Voice service not reachable"
      ;;
    *)
      echo "Usage: kolb-bot voice status"
      ;;
  esac
}

