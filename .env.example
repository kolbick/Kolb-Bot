# Kolb-Bot Configuration
# Copy to .env and fill in your values:  cp .env.example .env

# --- Required ---
KOLB_BOT_GATEWAY_TOKEN=changeme-generate-with-openssl-rand-hex-32
WEBUI_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# --- Ports (all exposed to tailnet for tablet/remote access) ---
KOLB_BOT_GATEWAY_PORT=18789
OPENWEBUI_PORT=3000
BRIDGE_PORT=8000
VOICE_PORT=8100
TELEMETRY_PORT=8200
NOVNC_PORT=6080
BROWSER_CDP_PORT=9222

# --- AI Provider API Keys (add the ones you use) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# OPENROUTER_API_KEY=sk-or-v1-...
# ELEVENLABS_API_KEY=...     # optional, for TTS
# BROWSER_USE_API_KEY=...    # optional, for browser automation

# --- Voice ---
STT_ENGINE=whisper
TTS_ENGINE=edge-tts
WHISPER_MODEL=base
# TTS_VOICE=en-US-AriaNeural

# --- Security ---
KOLB_BOT_SAFE_MODE=1
